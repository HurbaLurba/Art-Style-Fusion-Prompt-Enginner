# ─────────────────────────────────────────────────────────────────────────────
# Art Style Fusion Prompt Engineer — environment template
# Copy to .env and fill in the provider(s) you want to use.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=8000
NODE_ENV=production

# Provider selected on startup (used to prefill the UI / serve as default).
# One of: openai | openrouter | ollama | vllm | llamacpp | custom
ACTIVE_PROVIDER=

# ─────────────────────────────────────────────────────────────────────────────
# Providers — every backend speaks the OpenAI API. The server calls
#   {BASE_URL}/chat/completions   (text + vision via image_url content)
#   {BASE_URL}/models             (model discovery)
# BASE_URL must include the API version segment (usually /v1).
# API keys are optional for local servers (Ollama / vLLM / llama.cpp).
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

# Ollama (OpenAI-compatible endpoint exposed at /v1)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2-vision

# vLLM (OpenAI-compatible server; default port 8000)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_API_KEY=
VLLM_MODEL=

# llama.cpp (llama-server --api; default port 8080)
LLAMACPP_BASE_URL=http://localhost:8080/v1
LLAMACPP_API_KEY=
LLAMACPP_MODEL=

# Custom OpenAI-compatible endpoint
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# Generation defaults (overridable per request from the UI)
# ─────────────────────────────────────────────────────────────────────────────
GEN_TEMPERATURE=0.7
GEN_TOP_P=0.9
GEN_MAX_TOKENS=4096

# ─────────────────────────────────────────────────────────────────────────────
# Prompt overrides (optional — leave blank to use built-in defaults)
# ─────────────────────────────────────────────────────────────────────────────
BASE_IMAGE_PROMPT=
BASE_STYLE_PROMPT=
BASE_ARTIST_PROMPT=
BASE_PROMPT_GENERATION=
BASE_FLUX_PROMPT=
BASE_SDXL_PROMPT=
