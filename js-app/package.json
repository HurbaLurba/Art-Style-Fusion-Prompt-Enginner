{
  "name": "art-style-fusion-prompt-engineer",
  "version": "2.0.0",
  "description": "A modern JavaScript application for creating rich, detailed prompts by combining art styles, image descriptions, and artist inspirations",
  "main": "server/index.js",
  "scripts": {
  "dev": "concurrently \"npm run server\" \"npm run build:watch\"",
  "server": "nodemon server/index.js",
  "build": "webpack --config webpack.config.js --mode production",
  "build:watch": "webpack --config webpack.config.js --watch --mode development",
    "start": "node server/index.js"
  },
  "dependencies": {
  "@elastic/eui": "106.3.0",
  "@emotion/react": "^11.11.4",
  "@emotion/css": "^11.13.0",
  "@floating-ui/react": "^0.26.19",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "multer": "^2.0.2",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "sharp": "^0.32.6",
    "helmet": "^7.1.0",
  "express-rate-limit": "^7.1.5",
  "react": "18.2.0",
  "react-dom": "18.2.0",
  "process": "^0.11.10",
  "buffer": "^6.0.3"
  },
  "devDependencies": {
  "concurrently": "^8.2.2",
  "nodemon": "^3.0.1",
  "@types/node": "^20.8.0",
  "webpack": "^5.91.0",
  "webpack-cli": "^5.1.4",
  "babel-loader": "^9.1.3",
  "@babel/core": "^7.24.0",
  "@babel/preset-env": "^7.24.0",
