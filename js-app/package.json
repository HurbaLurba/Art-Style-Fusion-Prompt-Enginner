{
  "name": "art-style-fusion-prompt-engineer",
  "version": "3.0.0",
  "description": "Modern React 19 app for composing rich text-to-image prompts by fusing art styles, image analysis, and artist inspiration against any OpenAI-compatible LLM backend (OpenAI, OpenRouter, Ollama, vLLM, llama.cpp).",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:server:dev\" \"npm:client\"",
    "client": "vite",
    "server:dev": "nodemon server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "multer": "^2.0.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@mantine/core": "^8.1.0",
    "@mantine/dropzone": "^8.1.0",
    "@mantine/hooks": "^8.1.0",
    "@mantine/notifications": "^8.1.0",
    "@tabler/icons-react": "^3.31.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.0"
  },
  "keywords": [
    "ai",
    "prompt-engineering",
    "art",
    "image-analysis",
    "react",
    "mantine",
    "vite",
    "openai",
    "vllm",
    "llama.cpp",
    "ollama",
    "docker"
  ],
  "author": "ergonomech",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
